# Optional — increases GitHub API rate limit from 60 to 5000 req/hour
GITHUB_TOKEN=github_*************************

# Required for GitHub sign-in and persistent Pro entitlements
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_GITHUB_ID=github-oauth-app-client-id
AUTH_GITHUB_SECRET=github-oauth-app-client-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for Polar checkout and payment webhooks
POLAR_ACCESS_TOKEN=polar_oat_*************************
SUCCESS_URL=http://localhost:3000/?checkout=success&checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=whsec_*************************
POLAR_PRO_PRODUCT_ID=prod_*************************
POLAR_SERVER=sandbox
